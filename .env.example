# MongoDB Atlas Connection String
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<appName>
# Obtain from MongoDB Atlas: Cluster → Connect → Connect your application
# Requirements: 4.1 (Data Storage and Persistence)
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@<cluster>.mongodb.net/?appName=Cluster0

# Vercel Cron Secret
# This secret is used to authenticate cron job requests to /api/cron/update
# Generate a cryptographically secure random string (32+ bytes recommended)
# 
# Generate using one of these methods:
#   OpenSSL:    openssl rand -hex 32
#   Node.js:    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
# 
# Requirements: 11.5 (Scheduled Update Execution with Vercel cron)
CRON_SECRET=your-secret-key-here

# Node Environment
# Set to 'production' for production deployments
# Vercel automatically sets this to 'production' for production deployments
NODE_ENV=development
